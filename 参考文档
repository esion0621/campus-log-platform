-- 创建数据库
CREATE DATABASE IF NOT EXISTS campus_log DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE campus_log;

-- 学院表
CREATE TABLE college (
    college_id VARCHAR(10) PRIMARY KEY COMMENT '学院编号',
    college_name VARCHAR(50) NOT NULL COMMENT '学院名称'
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='学院信息表';

-- 学生信息表
CREATE TABLE student_info (
    student_id VARCHAR(20) PRIMARY KEY COMMENT '学号',
    name VARCHAR(50) NOT NULL COMMENT '姓名',
    college_id VARCHAR(10) NOT NULL COMMENT '所属学院编号',
    major VARCHAR(50) COMMENT '专业',
    enroll_year INT COMMENT '入学年份',
    FOREIGN KEY (college_id) REFERENCES college(college_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='学生基本信息表';

-- 设备信息表
CREATE TABLE device_info (
    device_id VARCHAR(20) PRIMARY KEY COMMENT '设备编号',
    device_name VARCHAR(50) NOT NULL COMMENT '设备名称',
    device_type ENUM('gate', 'canteen', 'server', 'network') NOT NULL COMMENT '设备类型',
    location VARCHAR(100) COMMENT '设备位置',
    status VARCHAR(10) DEFAULT 'online' COMMENT '状态'
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='设备信息表';

-- 食堂设备映射表
CREATE TABLE canteen_device (
    device_id VARCHAR(20) PRIMARY KEY COMMENT '设备编号',
    canteen_name VARCHAR(50) NOT NULL COMMENT '食堂名称',
    FOREIGN KEY (device_id) REFERENCES device_info(device_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='食堂设备关联表';

-- 图书信息表
CREATE TABLE book_info (
    book_id VARCHAR(20) PRIMARY KEY COMMENT '图书编号',
    title VARCHAR(200) NOT NULL COMMENT '书名',
    category VARCHAR(50) COMMENT '分类',
    author VARCHAR(50) COMMENT '作者'
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='图书信息表';

-- 学院周度入馆报表
CREATE TABLE report_library_weekly (
    week VARCHAR(10) NOT NULL COMMENT '周次，格式 YYYY-Www',
    college_id VARCHAR(10) NOT NULL COMMENT '学院编号',
    access_count BIGINT COMMENT '入馆总次数',
    PRIMARY KEY (week, college_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='学院周度入馆排行表';

-- 学生周度消费报表
CREATE TABLE report_consume_weekly (
    week VARCHAR(10) NOT NULL COMMENT '周次，格式 YYYY-Www',
    student_id VARCHAR(20) NOT NULL COMMENT '学号',
    total_amount DECIMAL(10,2) COMMENT '周消费总额',
    transaction_count INT COMMENT '周消费次数',
    PRIMARY KEY (week, student_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='学生周度消费统计表';

-- 学生画像标签表
CREATE TABLE student_tag (
    student_id VARCHAR(20) PRIMARY KEY COMMENT '学号',
    consumption_level VARCHAR(20) COMMENT '消费等级（高/中/低）',
    interest_tags VARCHAR(200) COMMENT '兴趣标签（逗号分隔）',
    last_update TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '最后更新时间'
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='学生画像标签表';
